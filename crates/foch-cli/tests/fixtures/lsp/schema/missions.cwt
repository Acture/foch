types = {
  type[mission] = {
    path = "game/missions"
  }
}

mission = {
  ## cardinality = 0..1
  ## replace_scope = { this = province root = country }
  ###Selects provinces relevant to the mission.
  provinces_to_highlight = {
    alias_name[trigger] = alias_match_left[trigger]
  }

  mission_tree = {
    ## replace_scope = { this = province root = country }
    <mission_stage> = {
      alias_name[trigger] = alias_match_left[trigger]
    }
  }
}
