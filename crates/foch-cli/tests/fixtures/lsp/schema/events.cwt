types = {
  type[event] = {
    path = "game/events"
    ## type_key_filter = country_event
    ## push_scope = country
    subtype[country] = {
    }
    localisation = {
      ## required
      title = "$_title"
      ## required
      desc = "$_desc"
    }
  }
}

event = {
  ## cardinality = 0..1
  ###Event title localisation key.
  title = scalar

  ## cardinality = 1..1
  ###Event monarch power category.
  category = enum[power_categories]

  ## required
  ###Named event target.
  target = value_set[event_targets]

  ###Saved event target to navigate to.
  goto = value[event_targets]

  ###How many days the event should use for fixture validation.
  days = int

  ###Relative chance weight for fixture validation.
  chance = float

  ###Whether the event should stay hidden for fixture validation.
  hidden = bool

  ###Conditions that must be true for the event to fire.
  trigger = {
    alias_name[trigger] = alias_match_left[trigger]
  }

  ## push_scope = country
  ## scope = { country province }
  ###Immediate effects executed when the event fires.
  immediate = {
    alias_name[effect] = alias_match_left[effect]
  }

  ## push_scope = province
  ###Effects executed in a province scope.
  province_effects = {
    alias_name[effect] = alias_match_left[effect]
  }
}

## scope = country
###Checks whether the current year matches.
alias[trigger:is_year] = int

## scope = country
###Checks whether the current country has a flag.
alias[trigger:has_country_flag] = scalar

## scope = province
###Checks whether the current province has a flag.
alias[trigger:has_province_flag] = scalar

## scope = sea
###Checks whether the current sea zone has a flag.
alias[trigger:has_sea_flag] = scalar

###Supports custom trigger bodies.
alias[trigger:custom_trigger] = {
  expected = scalar
}

## scope = country
###Adds prestige to the current country.
alias[effect:add_prestige] = int

## scope = country
###Country-level effect usable from province subscopes.
alias[effect:country_wide_effect] = int

## scope = province
###Province-only fixture effect.
alias[effect:province_only_effect] = int

enum[power_categories] = { ADM DIP MIL }
value_set[event_targets] = { root from prev }

scopes = {
  country = {
    aliases = { country root }
  }
  province = {
    aliases = { province from }
    is_subscope_of = { country }
  }
  sea = {
    aliases = { sea }
  }
}
