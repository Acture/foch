#!/usr/bin/env bash
# foch pre-push gate — runs the full workspace test suite.
# Override with FOCH_SKIP_PRE_PUSH=1 for hot-fix pushes.
set -e
if [[ "${FOCH_SKIP_PRE_PUSH:-0}" == "1" ]]; then
  echo "[foch] FOCH_SKIP_PRE_PUSH=1; skipping pre-push gate."
  exit 0
fi
cd "$(git rev-parse --show-toplevel)"
echo "[foch] cargo test --workspace"
cargo test --workspace --quiet
echo "[foch] pre-push OK"
